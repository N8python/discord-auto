{
  "manifest_version": 3,
  "name": "Discord LM Studio Auto Translate",
  "version": "0.2.0",
  "description": "Translates Discord between explicit source and target languages through an LM Studio OpenAI-compatible server.",
  "permissions": ["activeTab", "scripting", "storage", "unlimitedStorage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://discord.com/*",
        "https://*.discord.com/*",
        "https://discordapp.com/*",
        "https://*.discordapp.com/*"
      ],
      "js": ["page-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://discord.com/*",
        "https://*.discord.com/*",
        "https://discordapp.com/*",
        "https://*.discordapp.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Discord Auto Translate"
  }
}
